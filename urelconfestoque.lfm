  object ZReadOnlyQuery1: TZReadOnlyQuery
    Connection = dbConnect.ZConnection1
    SQL.Strings = (
      'Select pe.produto,p.codigo_barras,p.descricao,p.preco_compra,p.preco_venda_varejo,p.preco_venda_atacado,'
      'pe.lote,pe.quantidade'
      'from produtos_estoque pe'
      'Left Join produtos p ON pe.produto=p.id'
      'Where pe.quantidade > 0'
      'Order by pe.produto'
    )
    Params = <>
    left = 518
    top = 28
  end
