  object ZQuery1: TZQuery
    Connection = dbConnect.ZConnection1
    CachedUpdates = True
    SQL.Strings = (
      'Select i.id,i.produto,descricao,pe.lote,i.quantidade,i.quantidade as quant_estoque,0 as quant_dev,'
      'i.lote as id_lote'
      'from nfsaida_itens i'
      'Left Join produtos_estoque pe on pe.id=i.lote'
      'where nfsaida = :id'
      'Order by i.id'
    )
