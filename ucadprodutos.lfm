  object updProdutos: TZUpdateSQL
    DeleteSQL.Strings = (
      'DELETE FROM produtos'
      'WHERE'
      '  produtos.id = :OLD_id'
    )
    InsertSQL.Strings = (
      'INSERT INTO produtos'
      '  (id, descricao, codigo_barras, data_cadastro, grupo_produto, unidade, '
      '   preco_compra, margem_lucro_varejo, preco_venda_varejo, observacao, item_comercial, '
      '   prazo_validade, nao_movimenta_estoque, ncm, is_composed, largura, altura, '
      '   profundidade, peso, ipi_template_id, similares, origem, numero_reg_ms, '
      '   preco_venda_atacado, margem_lucro_atacado, tipo_produto, quant_caixa, '
      '   cmv, preco_venda_consignado, margem_lucro_consignado, ativo, caderno, '
      '   cest, lista_pis_cofins, p_pis, cst_pis, p_cofins, cst_cofins, tipo_produto_interno, '
      '   comissao, nfci_opc, desconto_de, desconto_ate, local_estoque, local_estoque_grosso, '
      '   quant_caixa_operacao, desconto_automatico, promocao_ate, em_promocao, '
      '   vbcstret, vicmsstret, picmsstret, c_class_trib, cst_ibs_cbs)'
      'VALUES'
      '  (:id, :descricao, :codigo_barras, :data_cadastro, :grupo_produto, :unidade, '
      '   :preco_compra, :margem_lucro_varejo, :preco_venda_varejo, :observacao, '
      '   :item_comercial, :prazo_validade, :nao_movimenta_estoque, :ncm, :is_composed, '
      '   :largura, :altura, :profundidade, :peso, :ipi_template_id, :similares, '
      '   :origem, :numero_reg_ms, :preco_venda_atacado, :margem_lucro_atacado, '
      '   :tipo_produto, :quant_caixa, :cmv, :preco_venda_consignado, :margem_lucro_consignado, '
      '   :ativo, :caderno, :cest, :lista_pis_cofins, :p_pis, :cst_pis, :p_cofins, '
      '   :cst_cofins, :tipo_produto_interno, :comissao, :nfci_opc, :desconto_de, '
      '   :desconto_ate, :local_estoque, :local_estoque_grosso, :quant_caixa_operacao, '
      '   :desconto_automatico, :promocao_ate, :em_promocao, :vbcstret, :vicmsstret, '
      '   :picmsstret, :c_class_trib, :cst_ibs_cbs)'
    )
