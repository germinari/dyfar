  object updProdutoICMS: TZUpdateSQL
    DeleteSQL.Strings = (
      'DELETE FROM produto_icms_template'
      'WHERE'
      '  produto_icms_template.id = :OLD_id'
    )
    InsertSQL.Strings = (
      'INSERT INTO produto_icms_template'
      '  (id, produto, uf_destino, bc_include_ipi, bc_st_include_ipi, cst_csosn, '
      '   mod_bc, mod_bc_st, p_cred_sn, p_cred_sn_valid_until, p_icms, p_icms_st, '
      '   p_mva_st, p_red_bc, p_red_bc_st, fcp, p_red_mvs_sn, preco_max_consumidor, '
      '   cbenef)'
      'VALUES'
      '  (:id, :produto, :uf_destino, :bc_include_ipi, :bc_st_include_ipi, :cst_csosn, '
      '   :mod_bc, :mod_bc_st, :p_cred_sn, :p_cred_sn_valid_until, :p_icms, :p_icms_st, '
      '   :p_mva_st, :p_red_bc, :p_red_bc_st, :fcp, :p_red_mvs_sn, :preco_max_consumidor, '
      '   :cbenef)'
    )
    ModifySQL.Strings = (
      'UPDATE produto_icms_template SET'
      '  id = :id,'
      '  produto = :produto,'
      '  uf_destino = :uf_destino,'
      '  bc_include_ipi = :bc_include_ipi,'
      '  bc_st_include_ipi = :bc_st_include_ipi,'
      '  cst_csosn = :cst_csosn,'
      '  mod_bc = :mod_bc,'
      '  mod_bc_st = :mod_bc_st,'
