  object qryEstoqueLotes: TZQuery
    Connection = dbConnect.ZConnection1
    UpdateObject = updEstoqueLotes
    SQL.Strings = (
      '(SELECT pe.id, pe.produto, pe.localizacao, pe.lote, pe.quantidade, pe.data_entrada, pe.data_validade, '
      '       pe.data_fabricacao,pe.empresa,e.abreviacao'
      '  FROM produtos_estoque pe'
      'Left Join empresa e ON e.id=pe.empresa'
      '  Where pe.produto = :id and pe.quantidade > 0)'
      'Union'
      '(SELECT id, produto,''Consignado'',(select lote From produtos_estoque Where id=ep.lote), '
      'quant_consignada, data_consignacao::::date, null, null, empresa,'
      '(Select nome_curto From empregados Where id=ep.empregado)::::varchar(20)'
      '  FROM empregados_produtos ep'
      '  Where ep.produto= :id )'
      'Order by data_validade NULLS FIRST,data_fabricacao NULLS FIRST,data_entrada NULLS FIRST'
    )
    Params = <    
      item
        Name = 'id'
      end>
    DataSource = dsProdutos
    Left = 222
    Top = 448
    ParamData = <    
      item
        Name = 'id'
      end>
