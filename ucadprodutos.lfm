  object qryProdutos: TZQuery
    AfterOpen = qryProdutosAfterOpen
    Connection = dbConnect.ZConnection1
    BeforePost = qryProdutosBeforePost
    AfterPost = qryProdutosAfterPost
    BeforeDelete = qryProdutosBeforeDelete
    OnNewRecord = qryProdutosNewRecord
    UpdateObject = updProdutos
    Active = True
    SQL.Strings = (
      'Select p.id, descricao, codigo_barras, data_cadastro, grupo_produto, unidade, '
      '       margem_lucro_varejo, preco_venda_varejo, observacao, '
      '       item_comercial, prazo_validade, nao_movimenta_estoque, ncm,  '
      '       is_composed, largura, altura, profundidade, peso,'
      '       ipi_template_id,  similares, origem, numero_reg_ms, '
      '       preco_venda_atacado, margem_lucro_atacado,'
      '(Select sum(quantidade) From produtos_estoque Where produtos_estoque.produto=p.id and quantidade > 0) as quant_geral,'
      '(Select sum(quantidade) From produtos_estoque Where produtos_estoque.produto=p.id and empresa= :empLocal and quantidade > 0) as quant_local,'
      '(Case When not  is_composed then  preco_compra'
      '         else (Select sum(preco*quantidade) From produtos_kit Where produto_master=p.id)'
      'end) as vpreco_compra,tipo_produto,ptp.nome as vtipo_produto,tipo_produto_interno,'
      'tpi.nome as vtipo_produto_interno,p.cmv,preco_venda_consignado,margem_lucro_consignado,ativo,'
      ' caderno,  cest,  lista_pis_cofins,  p_pis,  cst_pis ,  p_cofins,  cst_cofins ,'
      'obtemnometipoproduto( p.grupo_produto )::::varchar(200) as vnome_classificacao,'
      'quant_caixa,  comissao ,  nfci_opc,  desconto_ate,local_estoque,local_estoque_grosso,'
      'quant_caixa_operacao, desconto_automatico, promocao_ate,em_promocao,preco_compra,'
      'vbcstret,vicmsstret,picmsstret,c_class_trib,cst_ibs_cbs'
      'From produtos p'
      'Left Join tipo_produto_interno tpi ON tpi.id=p.tipo_produto_interno'
      'Left Join produto_tipo_produto ptp ON ptp.id=p.tipo_produto'
      'Where p.id = :id'
    )
    Params = <    
      item
        Name = 'empLocal'
      end    
      item
        Name = 'id'
      end>
    Left = 32
    Top = 448
    ParamData = <    
      item
        Name = 'empLocal'
      end    
      item
        Name = 'id'
      end>
    object qryProdutosid: TLongintField
      FieldKind = fkData
