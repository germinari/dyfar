      '  p_red_mvs_sn = :p_red_mvs_sn,'
      '  preco_max_consumidor = :preco_max_consumidor,'
      '  cbenef = :cbenef'
      'WHERE'
      '  produto_icms_template.id = :OLD_id'
    )
