  object qryItens: TZQuery
    Connection = dbConnect.ZConnection1
    UpdateObject = updItens
    SQL.Strings = (
      'Select i.*,pe.lote as vlote'
      'From nfsaida_itens i'
      'Left Join produtos p ON p.id=i.produto'
      'Left Join produtos_estoque pe ON pe.id=i.lote'
      'Where i.nfsaida= :id'
      'Order by i.id'
    )
    Params = <    
      item
        Name = 'id'
      end>
    DataSource = dsNota
    Left = 192
    Top = 432
    ParamData = <    
