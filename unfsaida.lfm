  object qryNFReferencia: TZReadOnlyQuery
    Connection = dbConnect.ZConnection1
    SQL.Strings = (
      'Select nfsaida_principal,nfsaida,nfentrada,'
      '(case when nfentrada > 0 then concat(nfe.fornecedor,''('',nfe.chave_nfe,'')'')'
      '     when nfsaida   > 0 then concat(nfs.destinatario,''('',nfs.chave_nfe,'')'')'
      'end)::::varchar(200) as nota_referenciada2 ,'
      '(case when nfentrada > 0 then nfe.chave_nfe'
      '          when nfsaida     > 0 then nfs.chave_nfe'
      'end)::::varchar(200) as nota_referenciada,'
      'nfr.id '
      ''
      'from nfsaida_referencias nfr'
      'Left Join nfentrada nfe ON nfe.id=nfr.nfentrada'
      'Left Join nfsaida   nfs ON nfs.id=nfr.nfsaida'
      ''
      'Where nfsaida_principal = :id'
    )
    Params = <    
