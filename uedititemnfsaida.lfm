  object ZUpdateSQL1: TZUpdateSQL
    DeleteSQL.Strings = (
      'DELETE FROM nfsaida_itens'
      'WHERE'
      '  nfsaida_itens.id = :OLD_id'
    )
    InsertSQL.Strings = (
      'INSERT INTO nfsaida_itens'
      '  (id, nfsaida, produto, descricao, quantidade, unidade, cst, ncm, origem, '
      '   valorunitario, valortotal, picms, lote, pdesconto, pmva, predst, baseicms, '
      '   vlricms, basesubst, vlrsubst, pcomissao, picmsst, redbase, peso, cfop, '
      '   modbc, modbcst, cst_pis, ppis, vbc_pis, cst_cofins, pcofins, vbc_cofins, '
      '   infadprod, estoque_origem, pipi, vbc_ipi, cst_ipi, vfrete, voutras, '
      '   indtot)'
      'VALUES'
