  object qryItens: TZQuery
    Connection = dbConnect.ZConnection1
    UpdateObject = ZUpdateSQL1
    SQL.Strings = (
      'Select i.*,p.quant_caixa,p.codigo_barras,p.ncm,nf.tipo_nota,nf.uf'
      'From nfsaida_itens i'
      'Left Join produtos p ON p.id=i.produto'
      'Left Join nfsaida nf ON i.nfsaida=nf.id'
      'Where i.id=:id'
    )
    Params = <    
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
    Left = 600
    Top = 32
