  object qryProduto: TZQuery
    Connection = dbConnect.ZConnection1
    SQL.Strings = (
      'Select p.*,pit.*,pe.lote as slote'
      'from produtos p'
      'Left Join produto_icms_template pit on pit.produto=p.id and pit.uf_destino= :uf'
      'Left Join produtos_estoque pe on pe.id= :lote'
      'Where p.id = :id'
    )
    Params = <    
      item
        DataType = ftUnknown
        Name = 'uf'
        ParamType = ptUnknown
      end    
      item
        DataType = ftUnknown
        Name = 'lote'
        ParamType = ptUnknown
      end    
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
