  object ZUpdateSQL1: TZUpdateSQL
    DeleteSQL.Strings = (
      'DELETE FROM empregados'
      'WHERE'
      '  empregados.id = :OLD_id'
    )
    InsertSQL.Strings = (
      'INSERT INTO empregados'
      '  (id, nome, endereco, cidade, bairro, cep, complemento, uf, email, telefone1, '
      '   telefone2, cpf, rg, funcao, observacao, dataadmissao, plano_contas, '
      '   senha_id, assinatura_email, nome_curto, comissao, sys_usuario)'
      'VALUES'
      '  (:id, :nome, :endereco, :cidade, :bairro, :cep, :complemento, :uf, :email, '
      '   :telefone1, :telefone2, :cpf, :rg, :funcao, :observacao, :dataadmissao, '
      '   :plano_contas, :senha_id, :assinatura_email, :nome_curto, :comissao, '
      '   :sys_usuario)'
    )
    ModifySQL.Strings = (
      'UPDATE empregados SET'
      '  id = :id,'
      '  nome = :nome,'
      '  endereco = :endereco,'
      '  cidade = :cidade,'
      '  bairro = :bairro,'
      '  cep = :cep,'
      '  complemento = :complemento,'
      '  uf = :uf,'
      '  email = :email,'
      '  telefone1 = :telefone1,'
      '  telefone2 = :telefone2,'
      '  cpf = :cpf,'
      '  rg = :rg,'
      '  funcao = :funcao,'
      '  observacao = :observacao,'
      '  dataadmissao = :dataadmissao,'
      '  plano_contas = :plano_contas,'
      '  senha_id = :senha_id,'
      '  assinatura_email = :assinatura_email,'
      '  nome_curto = :nome_curto,'
      '  comissao = :comissao,'
      '  sys_usuario = :sys_usuario'
      'WHERE'
      '  empregados.id = :OLD_id'
    )
    UseSequenceFieldForRefreshSQL = False
    left = 616
    top = 488
