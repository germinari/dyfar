  object qryProdutosConsig: TZQuery
    Connection = dbConnect.ZConnection1
    AfterOpen = qryProdutosConsigAfterOpen
    OnCalcFields = qryProdutosConsigCalcFields
    UpdateObject = ZUpdateSQL2
    SQL.Strings = (
      'Select false as selecionado,ep.*,p.descricao,p.codigo_barras,l.lote as slote'
      'From empregados_produtos ep'
      'Left Join produtos p ON p.id=ep.produto'
      'Left Join produtos_estoque l ON l.id=ep.lote'
      'Where empregado=:id and ( quant_vendida <> quant_consignada)'
    )
