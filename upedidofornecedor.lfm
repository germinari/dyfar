  object qryPedidoComprasItens: TZQuery
    Connection = dbConnect.ZConnection1
    SortedFields = 'descricao'
    OnCalcFields = qryPedidoComprasItensCalcFields
    BeforePost = qryPedidoComprasItensBeforePost
    SQL.Strings = (
      'Select p.id,p.descricao,fp.fornecedor, pci.*,'
      '(Select coalesce(sum(quantidade),0.00) From produtos_estoque Where produto=p.id and quantidade > 0) as quantidade_estoque,'
      'p.unidade,p.preco_compra, fp.codigo_produto,fp.descricao_produto,p.quant_caixa,p.preco_venda_atacado,'
      'coalesce((Select sum(quantidade) From nfsaida_itens i'
      ' Left Join nfsaida nf on nf.id=i.nfsaida'
      ' Where nf.status_nfe in (4,5,8) and produto=p.id and nf.dataemissao >= ( CURRENT_DATE - interval ''1 MONTH'') ) ,0.00) AS giro_30 '
      'from produtos p'
      'Left Join pedido_compra_itens pci on  (pci.pedido_compra = :id and pci.produto=p.id)'
      'Left Join fornecedor_produto fp on fp.produto=p.id'
      'Where fp.fornecedor = :fornecedor and p.ativo=true'
      ''
    )
    Params = <    
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end    
      item
        DataType = ftUnknown
        Name = 'fornecedor'
        ParamType = ptUnknown
      end>
    IndexFieldNames = 'descricao Asc'
    left = 168
    top = 520
    ParamData = <    
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end    
      item
        DataType = ftUnknown
        Name = 'fornecedor'
        ParamType = ptUnknown
      end>
