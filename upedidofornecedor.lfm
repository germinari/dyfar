  object updPedidoCompra: TZUpdateSQL
    DeleteSQL.Strings = (
      'DELETE FROM pedido_compra'
      'WHERE'
      '  pedido_compra.id = :OLD_id'
    )
    InsertSQL.Strings = (
      'INSERT INTO pedido_compra'
      '  (id, data, fornecedor, observacao, prazo_pgto, forma_pgto, dt_entrega, '
      '   status, desconto)'
      'VALUES'
      '  (:id, :data, :fornecedor, :observacao, :prazo_pgto, :forma_pgto, :dt_entrega, '
      '   :status, :desconto)'
    )
    ModifySQL.Strings = (
      'UPDATE pedido_compra SET'
      '  id = :id,'
      '  data = :data,'
      '  fornecedor = :fornecedor,'
      '  observacao = :observacao,'
      '  prazo_pgto = :prazo_pgto,'
      '  forma_pgto = :forma_pgto,'
      '  dt_entrega = :dt_entrega,'
      '  status = :status,'
      '  desconto = :desconto'
      'WHERE'
      '  pedido_compra.id = :OLD_id'
    )
    UseSequenceFieldForRefreshSQL = False
    left = 110
    top = 567
    ParamData = <    
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end    
      item
        DataType = ftUnknown
        Name = 'data'
        ParamType = ptUnknown
      end    
      item
        DataType = ftUnknown
        Name = 'fornecedor'
        ParamType = ptUnknown
      end    
