  object ZReadOnlyQuery1: TZReadOnlyQuery
    Connection = dbConnect.ZConnection1
    SQL.Strings = (
      'Select p.id,p.descricao,preco, desconto,(preco- (preco*desconto/100))::::numeric(10,2) as preco_desc , sum(quantidade), sum(quantidade) * (preco- (preco*desconto/100))::::numeric(10,2) as total'
      ' from balcao_venda bv '
      'Left Join balcao_venda_itens bi ON bv.id=bi.balcao_venda Left Join produtos p ON p.id=bi.produto Where ((cast(data as date) >= cast(''01/02/2014'' as date) and cast(data as date) <= cast(''08/02/2014'' as date))) Group by p.id,descricao,preco,desconto Order by descricao,preco'
    )
    Params = <>
    left = 440
    top = 128
  end
  object Datasource1: TDataSource
    DataSet = ZReadOnlyQuery1
    left = 440
    top = 184
  end
