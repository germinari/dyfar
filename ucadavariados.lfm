  object qryQuarentena: TZQuery
    Connection = dbConnect.ZConnection1
    SortedFields = 'datahora'
    SQL.Strings = (
      'Select peq.datahora,pe.produto,      '
      '(case when p.descricao is null then ''ITEM NAO CONSTA DO CADASTRO DE PRODUTOS'''
      ' else p.descricao end)::::varchar(80) as descricao,'
      ' pe.lote as slote,'
      ' pe.data_validade,'
      ' peq.quant_sobra as quantidade,'
      ' peq.id,peq.lote,peq.motivo'
      'From produtos_estoque_quarentena peq'
      'Left Join produtos_estoque pe ON (pe.id=peq.lote)'
      'Left Join produtos p ON p.id=pe.produto '
    )
    Params = <>
    IndexFieldNames = 'datahora Asc'
    left = 311
    top = 232
