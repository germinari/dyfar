  object updAvariado: TZUpdateSQL
    DeleteSQL.Strings = (
      'DELETE FROM produtos_estoque_avariado'
      'WHERE'
      '  produtos_estoque_avariado.id = :OLD_id'
    )
    InsertSQL.Strings = (
      'INSERT INTO produtos_estoque_avariado'
      '  (id, lote, datahora, quant_sobra, quant_falta, motivo)'
      'VALUES'
      '  (:id, :lote, :datahora, :quant_sobra, :quant_falta, :motivo)'
    )
    ModifySQL.Strings = (
      'UPDATE produtos_estoque_avariado SET'
      '  id = :id,'
      '  lote = :lote,'
      '  datahora = :datahora,'
      '  quant_sobra = :quant_sobra,'
      '  quant_falta = :quant_falta,'
      '  motivo = :motivo'
      'WHERE'
      '  produtos_estoque_avariado.id = :OLD_id'
    )
    UseSequenceFieldForRefreshSQL = False
    left = 448
    top = 264
    ParamData = <    
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end    
      item
        DataType = ftUnknown
        Name = 'lote'
        ParamType = ptUnknown
      end    
      item
        DataType = ftUnknown
        Name = 'datahora'
        ParamType = ptUnknown
      end    
      item
        DataType = ftUnknown
        Name = 'quant_sobra'
        ParamType = ptUnknown
      end    
      item
        DataType = ftUnknown
        Name = 'quant_falta'
        ParamType = ptUnknown
      end    
      item
        DataType = ftUnknown
        Name = 'motivo'
        ParamType = ptUnknown
      end    
      item
        DataType = ftUnknown
        Name = 'OLD_id'
        ParamType = ptUnknown
      end>
  end
