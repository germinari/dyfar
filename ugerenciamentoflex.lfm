  object qryListaRep: TZQuery
    Connection = dbConnect.ZConnection1
    SQL.Strings = (
      'Select id,nome,'
      '(Select sum(credito-debito) From conta_corrente_flex Where representante=e.id)  as saldo,'
      '(Select count(*) > 0 From gcm Where vendedor=e.id) as connected,'
      '(Select dh_registro From gcm Where vendedor=e.id) as dh_registro'
      'From empregados e'
      'Where funcao=''REPRESENTANTE'''
      'Order by nome'
    )
    Params = <>
    left = 16
    top = 219
