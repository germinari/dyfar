  object qryCtaCorrente: TZQuery
    Connection = dbConnect.ZConnection1
    SQL.Strings = (
      'SELECT ccf.id, nfsaida, representante, dh_movimento, historico, credito, '
      '       debito,nf.numeroctlform'
      '  FROM conta_corrente_flex ccf'
      'Left join nfsaida nf ON nf.id=ccf.nfsaida'
      'Where representante = :id'
      'Order by dh_movimento'
    )
    Params = <    
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
