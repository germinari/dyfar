  object ZUpdateSQL1: TZUpdateSQL
    DeleteSQL.Strings = (
      'DELETE FROM nfentrada_md'
      'WHERE'
      '  nfentrada_md.nsu = :OLD_nsu'
    )
    InsertSQL.Strings = (
      'INSERT INTO nfentrada_md'
      '  (nsu, tipo_evento, data_hora, chave_nfe, vnf, xnome, ssitdfe, oid_xml, '
      '   evento_registrado)'
      'VALUES'
      '  (:nsu, :tipo_evento, :data_hora, :chave_nfe, :vnf, :xnome, :ssitdfe, '
      '   :oid_xml, :evento_registrado)'
    )
    ModifySQL.Strings = (
      'UPDATE nfentrada_md SET'
      '  nsu = :nsu,'
      '  tipo_evento = :tipo_evento,'
      '  data_hora = :data_hora,'
      '  chave_nfe = :chave_nfe,'
      '  vnf = :vnf,'
      '  xnome = :xnome,'
      '  ssitdfe = :ssitdfe,'
      '  oid_xml = :oid_xml,'
      '  evento_registrado = :evento_registrado'
      'WHERE'
      '  nfentrada_md.nsu = :OLD_nsu'
    )
    UseSequenceFieldForRefreshSQL = False
    left = 1158
    top = 49
    ParamData = <    
      item
        DataType = ftUnknown
