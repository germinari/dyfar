  object ZQuery1: TZQuery
    Connection = dbConnect.ZConnection1
    UpdateObject = ZUpdateSQL1
    SQL.Strings = (
      'SELECT false as selecionado,(coalesce(oid_xml,0) > 0) as baixado, nsu,tipo_evento , '
      'data_hora , chave_nfe ,'
      'substr(chave_nfe,7,14)::::varchar(14) AS cnpj, '
      'substr(chave_nfe,26,9)::::varchar(9) AS nnfe  ,'
      'vnf,xnome,ssitdfe, oid_xml,evento_registrado'
      'FROM nfentrada_md nm '
      'WHERE tipo_evento = ''resNFe'''
      'Order by nsu desc'
      'Limit :limite'
    )
    Params = <    
      item
        DataType = ftUnknown
        Name = 'limite'
        ParamType = ptUnknown
      end>
    left = 1096
    top = 56
    ParamData = <    
      item
        DataType = ftUnknown
        Name = 'limite'
        ParamType = ptUnknown
      end>
