  object updClientes: TZUpdateSQL
    DeleteSQL.Strings = (
      'DELETE FROM clientes'
      'WHERE'
      '  clientes.id = :OLD_id'
    )
    InsertSQL.Strings = (
      'INSERT INTO clientes'
      '  (id, nome, fantasia, endereco, cidade, bairro, cep, complemento, uf, '
      '   email, telefone1, telefone2, fax, contato, cnpj, inscestadual, observacao, '
      '   status, datacadastro, plano_contas, limite_credito, tabela_preco, atividade, '
      '   cliente_grupo, tipo_estabelecimento, webpage, transportadora, cnae, '
      '   crt, prazo_pagamento, data_lic_sanitaria, cidade_ibge, entrega_cep, '
      '   entrega_uf, entrega_cidade, entrega_bairro, entrega_endereco, entrega_complemento, '
      '   entrega_cnpjcpf)'
      'VALUES'
      '  (:id, :nome, :fantasia, :endereco, :cidade, :bairro, :cep, :complemento, '
      '   :uf, :email, :telefone1, :telefone2, :fax, :contato, :cnpj, :inscestadual, '
      '   :observacao, :status, :datacadastro, :plano_contas, :limite_credito, '
      '   :tabela_preco, :atividade, :cliente_grupo, :tipo_estabelecimento, :webpage, '
      '   :transportadora, :cnae, :crt, :prazo_pagamento, :data_lic_sanitaria, '
      '   :cidade_ibge, :entrega_cep, :entrega_uf, :entrega_cidade, :entrega_bairro, '
      '   :entrega_endereco, :entrega_complemento, :entrega_cnpjcpf)'
    )
    ModifySQL.Strings = (
      'UPDATE clientes SET'
      '  id = :id,'
