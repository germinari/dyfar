  object qryCtaReceber: TZQuery
    Connection = dbConnect.ZConnection1
    SQL.Strings = (
      'SELECT (conta_credito||''-''||pc.descricao)::::varchar(80) as vdescricao_credito,'
      '       pc.conta as vconta_credito,'
      '       cp.id, id_nf, documento, cp.descricao, dataconta, data_vencimento, '
      '       data_pagamento, valor_devido, desconto, juros, valor_pago, observacao, '
      '       conta_credito, conta_debito, banco_negociado, parcela, total_parcelas, '
      '       cliente'
      '  FROM contas_receber cp'
      '  Left Join plano_contas pc ON cp.conta_credito=pc.id'
      'Where cliente=:id'
    )
    Params = <    
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
    DataSource = dsClientes
    Left = 528
    Top = 451
    ParamData = <    
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
