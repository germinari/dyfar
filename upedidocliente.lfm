  object qryListaPedidos: TZQuery
    Connection = dbConnect.ZConnection1
    OnCalcFields = qryListaPedidosCalcFields
    SQL.Strings = (
      'SELECT pv.id, data, cliente,'''' as nome, '''' as cnpj, origem_pedido, status, representante,'
      'e.nome as vrepresentante,'
      'coalesce((Select sum(preco_unitario*quantidade - (preco_unitario*quantidade * desconto/100)+vlr_subst*quantidade) from pedido_venda_itens i Where i.pedido_venda=pv.id),0.00) as total'
      'FROM pedido_venda pv'
      'left join empregados e on e.id=pv.representante'
      'Where status = 0'
      'Order by data'
    )
    Params = <>
    left = 64
    top = 528
