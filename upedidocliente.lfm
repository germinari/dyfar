  object qryPedidoVenda: TZQuery
    Connection = dbConnect.ZConnection1
    UpdateObject = updPedidoVenda
    OnNewRecord = qryPedidoVendaNewRecord
    SQL.Strings = (
      'SELECT pv.*,c.nome,c.cnpj,c.telefone1,c.uf,c.email,c.contato,'
      'e.nome as vrepresentante,c.endereco,c.cidade,c.cep, crt, c.bairro'
      'FROM pedido_venda pv'
      'LEFT JOIN clientes c ON c.id=pv.cliente'
      'LEFT JOIN empregados e ON e.id=pv.representante'
      'WHERE pv.id= :id'
    )
    Params = <    
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
    left = 136
    top = 668
