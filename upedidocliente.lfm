  object qryPedidoVendaItens: TZQuery
    Connection = dbConnect.ZConnection1
    SortedFields = 'id'
    SortType = stDescending
    OnCalcFields = qryPedidoVendaItensCalcFields
    UpdateObject = updPedidoVendaItens
    AfterPost = qryPedidoVendaItensAfterPost
    AfterDelete = qryPedidoVendaItensAfterDelete
    SQL.Strings = (
      'Select pi.*,p.unidade,pe.lote as slote,p.descricao,p.local_estoque,p.local_estoque_grosso'
      'From pedido_venda_itens pi'
      'left join produtos p on p.id=pi.produto'
      'left join produtos_estoque pe on pe.id=pi.lote'
      'Where pi.pedido_venda =:id'
      ''
    )
    Params = <    
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
