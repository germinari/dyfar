  object qryLocacaoItens: TZQuery
    Connection = dbConnect.ZConnection1
    UpdateObject = updLocacaoItens
    AfterPost = qryLocacaoItensAfterPost
    BeforeDelete = qryLocacaoItensBeforeDelete
    SQL.Strings = (
      'Select li.*,p.descricao'
      'From locacao_itens li'
      'Left Join produtos p ON p.id=li.produto'
      'Where locacao = :id'
      'Order by id'
    )
    Params = <    
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
    DataSource = dsLocacao
    left = 360
    top = 432
    ParamData = <    
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
