  object updLocacaoItens: TZUpdateSQL
    DeleteSQL.Strings = (
      'DELETE FROM locacao_itens'
      'WHERE'
      '  locacao_itens.id = :OLD_id'
    )
    InsertSQL.Strings = (
      'INSERT INTO locacao_itens'
      '  (id, locacao, produto, data_inicio, data_termino, quantidade, situacao, '
      '   valor, pgto_antecipado, lancado)'
      'VALUES'
      '  (:id, :locacao, :produto, :data_inicio, :data_termino, :quantidade, :situacao, '
      '   :valor, :pgto_antecipado, :lancado)'
