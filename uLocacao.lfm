  object qryEstqLocacao: TZQuery
    Connection = dbConnect.ZConnection1
    UpdateObject = updEstqLocacao
    SQL.Strings = (
      'Select pl.*,p.descricao,'
      'coalesce((Select sum(quantidade) From locacao_itens Where situacao=0 and produto=p.id),0) as locado,'
      '(Select lote From produtos_estoque Where id=pl.produto_estoque) as lote'
      'From produtos_locacao pl'
      'Left Join produtos p ON p.id=pl.produto'
    )
    Params = <>
    left = 96
    top = 432
