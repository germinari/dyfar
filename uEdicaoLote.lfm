  object ZUpdateSQL1: TZUpdateSQL
    DeleteSQL.Strings = (
      'DELETE FROM produtos_estoque'
      'WHERE'
      '  produtos_estoque.id = :OLD_id'
    )
    InsertSQL.Strings = (
      'INSERT INTO produtos_estoque'
      '  (produto, lote, quantidade, data_entrada, data_validade, data_fabricacao, '
      '   empresa, localizacao)'
      'VALUES'
      '  (:produto, :lote, :quantidade, :data_entrada, :data_validade, :data_fabricacao, '
      '   :empresa, :localizacao)'
    )
    ModifySQL.Strings = (
      'UPDATE produtos_estoque SET'
      '  produto = :produto,'
      '  lote = :lote,'
      '  quantidade = :quantidade,'
      '  data_entrada = :data_entrada,'
      '  data_validade = :data_validade,'
      '  data_fabricacao = :data_fabricacao,'
      '  empresa = :empresa,'
      '  localizacao = :localizacao'
      'WHERE'
      '  produtos_estoque.id = :OLD_id'
    )
    UseSequenceFieldForRefreshSQL = False
    left = 456
    top = 152
    ParamData = <    
      item
        DataType = ftUnknown
        Name = 'produto'
        ParamType = ptUnknown
      end    
      item
