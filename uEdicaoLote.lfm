  object qryEstoqueLotes: TZQuery
    Connection = dbConnect.ZConnection1
    UpdateObject = ZUpdateSQL1
    SQL.Strings = (
      'SELECT pe.id, pe.produto, pe.localizacao, pe.lote, pe.quantidade, pe.data_entrada, pe.data_validade, '
      '       pe.data_fabricacao,pe.empresa,p.descricao,(e.id||''-''||e.nome)::::varchar(80) as nomeemp,p.prazo_validade'
      '  FROM produtos_estoque pe'
      ' Left Join produtos p ON p.id=pe.produto'
      ' Left Join empresa e ON e.id=pe.empresa'
      '  Where pe.id = :id'
      '  Order by pe.data_validade'
    )
    Params = <    
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
    left = 440
    top = 80
    ParamData = <    
      item
        DataType = ftUnknown
        Name = 'id'
        ParamType = ptUnknown
      end>
