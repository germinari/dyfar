  object updFornecedor: TZUpdateSQL
    DeleteSQL.Strings = (
      'DELETE FROM fornecedores'
      'WHERE'
      '  fornecedores.id = :OLD_id'
    )
    InsertSQL.Strings = (
      'INSERT INTO fornecedores'
      '  (id, nome, fantasia, endereco, cidade, bairro, cep, complemento, uf, '
      '   email, telefone1, telefone2, fax, contato, cnpj, inscestadual, observacao, '
      '   status, datacadastro, plano_contas, webpage)'
      'VALUES'
      '  (:id, :nome, :fantasia, :endereco, :cidade, :bairro, :cep, :complemento, '
      '   :uf, :email, :telefone1, :telefone2, :fax, :contato, :cnpj, :inscestadual, '
      '   :observacao, :status, :datacadastro, :plano_contas, :webpage)'
    )
    ModifySQL.Strings = (
      'UPDATE fornecedores SET'
      '  id = :id,'
      '  nome = :nome,'
      '  fantasia = :fantasia,'
      '  endereco = :endereco,'
      '  cidade = :cidade,'
      '  bairro = :bairro,'
      '  cep = :cep,'
      '  complemento = :complemento,'
      '  uf = :uf,'
      '  email = :email,'
      '  telefone1 = :telefone1,'
      '  telefone2 = :telefone2,'
      '  fax = :fax,'
      '  contato = :contato,'
      '  cnpj = :cnpj,'
      '  inscestadual = :inscestadual,'
      '  observacao = :observacao,'
      '  status = :status,'
      '  datacadastro = :datacadastro,'
      '  plano_contas = :plano_contas,'
      '  webpage = :webpage'
      'WHERE'
      '  fornecedores.id = :OLD_id'
    )
    UseSequenceFieldForRefreshSQL = False
    Left = 592
    Top = 24
    ParamData = <    
