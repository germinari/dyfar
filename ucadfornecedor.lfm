  object qryFornecedor: TZQuery
    Connection = dbConnect.ZConnection1
    UpdateObject = updFornecedor
    AfterPost = qryFornecedorAfterPost
    OnNewRecord = qryFornecedorNewRecord
    SQL.Strings = (
      'Select f.*,p.conta||''-''||p.descricao as vplano_contas,'
      '          u.nome as uf_nome'
      'from fornecedores f'
      'Left Join plano_contas p ON p.id=f.plano_contas'
      'Left Join unidade_federacao u ON u.sigla=f.uf'
      'Where f.id =:id'
    )
    Params = <    
