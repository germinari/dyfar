  object qryCtaReceber: TZQuery
    AfterOpen = qryCtaReceberAfterOpen
    OnCalcFields = qryCtaReceberCalcFields
    Connection = dbConnect.ZConnection1
    UpdateObject = ZUpdateSQL1
    SQL.Strings = (
      'SELECT (conta_credito||''-''||pc.descricao)::::varchar(80) as vdescricao_credito,'
      '       pc.conta as vconta_credito,'
      '       cr.id, id_nf, documento, cr.descricao, dataconta, cr.data_vencimento, '
      '       data_pagamento, valor_devido, desconto, juros, valor_pago, observacao, '
      '       conta_credito, conta_debito, banco_negociado, cr.parcela, total_parcelas, '
      '       cliente,cr.conta, false as selecionado, b.id as boleto,b.nosso_numero,b.remessa,'
      '       b.banco,cr.origem'
      '  FROM contas_receber cr'
      '  Left Join boleto_contas_receber bc ON bc.contas_receber=cr.id'
      '  Left Join boleto                b  ON b.id=bc.boleto'
      '  Left Join plano_contas pc ON cr.conta_credito=pc.id'
      'Limit 0'
    )
    Params = <>
    Left = 416
    Top = 208
