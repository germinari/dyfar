      'INSERT INTO contas_receber'
      '  (id, id_nf, documento, descricao, dataconta, data_vencimento, data_pagamento, '
      '   valor_devido, desconto, juros, valor_pago, observacao, conta_credito, '
      '   conta_debito, banco_negociado, cliente, parcela, total_parcelas, conta, '
